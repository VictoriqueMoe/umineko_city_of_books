{
    "name": "umineko-city-of-books",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:app": "tsc -b && vite build --mode app --outDir dist-app --emptyOutDir",
        "build:ota": "npm run build:app && node scripts/make-ota.mjs",
        "cap:sync": "npm run build:app && cap sync",
        "cap:android": "npm run build:app && cap sync android && cap open android",
        "assets": "capacitor-assets generate --android --iconBackgroundColor \"#0A0612\" --iconBackgroundColorDark \"#0A0612\" --splashBackgroundColor \"#0A0612\" --splashBackgroundColorDark \"#0A0612\"",
        "test": "vitest run",
        "preview": "vite preview",
        "lint": "eslint --max-warnings=0 .",
        "lint:fix": "eslint . --fix",
        "prettier": "prettier ./src --check",
        "prettier:fix": "prettier ./src --write"
    },
    "dependencies": {
        "@capacitor/android": "^8.4.0",
        "@capacitor/app": "^8.1.0",
        "@capacitor/cli": "^8.4.0",
        "@capacitor/core": "^8.4.0",
        "@capacitor/ios": "^8.4.0",
        "@capacitor/preferences": "^8.0.1",
        "@capacitor/push-notifications": "^8.1.1",
        "@capacitor/splash-screen": "^8.0.1",
        "@capacitor/status-bar": "^8.0.2",
        "@capgo/capacitor-updater": "^8.49.1",
        "@hyperbeam/web": "^0.0.38",
        "@livekit/components-react": "^2.9.21",
        "@marsidev/react-turnstile": "^1.5.3",
        "@tanstack/react-query": "^5.101.0",
        "@tiptap/extension-color": "^3.26.1",
        "@tiptap/extension-link": "^3.26.1",
        "@tiptap/extension-placeholder": "^3.26.1",
        "@tiptap/extension-text-align": "^3.26.1",
        "@tiptap/extension-text-style": "^3.26.1",
        "@tiptap/pm": "^3.26.1",
        "@tiptap/react": "^3.26.1",
        "@tiptap/starter-kit": "^3.26.1",
        "chess.js": "^1.4.0",
        "dompurify": "^3.4.9",
        "emoji-picker-react": "^4.19.1",
        "highlight.js": "^11.11.1",
        "livekit-client": "^2.19.2",
        "marked": "^18.0.5",
        "react": "^19.2.7",
        "react-chessboard": "^5.10.0",
        "react-dom": "^19.2.7",
        "react-router": "^7.17.0"
    },
    "devDependencies": {
        "@capacitor/assets": "^3.0.5",
        "@eslint/js": "^10.0.1",
        "@types/dompurify": "^3.2.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "adm-zip": "^0.5.17",
        "eslint": "^10.4.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "jsdom": "^29.1.1",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vitest": "^4.1.8"
    }
}
