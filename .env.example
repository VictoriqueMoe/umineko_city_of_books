BASE_URL=http://localhost:4323
UPLOAD_DIR=uploads
LOG_LEVEL=debug

# Database connection. Either set DATABASE_URL directly,
# or rely on the discrete POSTGRES_* vars (POSTGRES_USER/PASSWORD/DB live in postgres.env).
# DATABASE_URL=postgres://umineko:foo@localhost:5007/umineko_city_of_books?sslmode=disable
POSTGRES_HOST=postgres
POSTGRES_SSL_MODE=disable

HYPERBEAM_API_KEY=
HYPERBEAM_REGION=EU

# Native push (Firebase Cloud Messaging). Path to the Firebase service-account
# JSON, mounted read-only into the container. Leave empty to disable native push.
# Also requires the push_enabled site setting to be turned on in admin.
FCM_CREDENTIALS_FILE=
