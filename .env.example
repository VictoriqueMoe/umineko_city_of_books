BASE_URL=http://localhost:4323
UPLOAD_DIR=uploads
LOG_LEVEL=debug

# Database connection. Either set DATABASE_URL directly,
# or rely on the discrete POSTGRES_* vars (POSTGRES_USER/PASSWORD/DB live in postgres.env).
# DATABASE_URL=postgres://umineko:foo@localhost:5007/umineko_city_of_books?sslmode=disable
POSTGRES_HOST=postgres
POSTGRES_SSL_MODE=disable
