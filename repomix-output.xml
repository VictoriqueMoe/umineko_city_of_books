	if key != config.SettingLogLevel.Key {
		return
	}

	level, err := zerolog.ParseLevel(value)
	if err != nil {
		return
	}

	zerolog.SetGlobalLevel(level)
	Log.Info().Str("level", value).Msg("log level changed")
}
