<file path="frontend/src/pages/theories/TheoryPage.module.css">
.page {
    max-width: 900px;
    margin: 0 auto;
}

.backBtn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 0.9rem;
