		if err := rows.Scan(&u.ID, &u.Username, &u.DisplayName, &u.AvatarURL, &u.Role); err != nil {
			return nil, fmt.Errorf("scan mutual: %w", err)
		}
		users = append(users, u)
	}
	return users, rows.Err()
}
