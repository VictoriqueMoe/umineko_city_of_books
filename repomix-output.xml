<file path="frontend/src/styles/global.css">
/* CSS Reset */

*,
*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
}

body {
    font-family: var(--font-body);
    color: var(--text);
    background-color: var(--bg-void);
    min-height: 100vh;
    line-height: 1.6;
    overflow-x: hidden;
}

#root {
    min-height: 100vh;
}

.app-layout {
    display: flex;
    min-height: 100vh;
}

.app-main {
    flex: 1;
    margin-left: 290px;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

a {
    color: var(--gold);
    text-decoration: none;
}

a:hover {
    color: var(--gold-light);
}

button {
    font-family: var(--font-body);
    cursor: pointer;
}

input,
textarea,
select {
    font-family: var(--font-body);
}

/* Truth text colours (used inline via dangerouslySetInnerHTML) */

.red-truth {
    color: #ff3333;
    font-weight: 600;
}

.blue-truth {
    color: #3399ff;
    font-weight: 600;
}

.gold-truth {
    color: #ffaa00;
    font-weight: 600;
}

.purple-truth {
    color: #aa71ff;
    font-weight: 600;
}

/* Main layout */

.main-content {
    flex: 1;
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
}

/* Loading & Empty states */

.loading {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
    font-size: 1.1rem;
    font-style: italic;
}

.empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
    font-size: 1.1rem;
}

/* Butterflies & Particles (injected via DOM, must be global) */

.butterfly {
    position: absolute;
    font-size: 1.2rem;
    color: var(--gold);
    text-shadow:
        0 0 15px var(--gold),
        0 0 30px rgba(var(--gold-rgb), 0.5);
    filter: blur(0.5px);
    animation: flutter var(--duration, 25s) var(--delay, 0s) infinite linear backwards;
}

.particle {
    position: absolute;
    color: var(--gold);
    text-shadow: 0 0 10px var(--gold);
    pointer-events: none;
    animation: particle-rise var(--duration, 25s) var(--delay, 0s) infinite linear backwards;
}

@keyframes flutter {
    0% {
        transform: translateY(100vh) translateX(var(--start-x, 0)) rotate(0deg) scale(0.8);
        opacity: 0;
    }
    5% {
        opacity: 0.7;
    }
    25% {
        transform: translateY(75vh) translateX(calc(var(--start-x, 0) + 80px)) rotate(90deg) scale(1);
    }
    50% {
        transform: translateY(50vh) translateX(calc(var(--start-x, 0) - 40px)) rotate(180deg) scale(1.1);
        opacity: 0.8;
    }
    75% {
        transform: translateY(25vh) translateX(calc(var(--start-x, 0) + 60px)) rotate(270deg) scale(1);
    }
    95% {
        opacity: 0.6;
    }
    100% {
        transform: translateY(-10vh) translateX(var(--start-x, 0)) rotate(360deg) scale(0.9);
        opacity: 0;
    }
}

@keyframes particle-rise {
    0% {
        transform: translateY(100vh) translateX(var(--start-x, 0)) rotate(0deg);
        opacity: 0;
    }
    10% {
        opacity: 0.3;
    }
    50% {
        transform: translateY(50vh) translateX(calc(var(--start-x, 0) + 40px)) rotate(180deg);
        opacity: 0.35;
    }
    90% {
        opacity: 0.25;
    }
    100% {
        transform: translateY(-10vh) translateX(var(--start-x, 0));
        opacity: 0;
    }
}

/* Responsive layout */

@media (max-width: 960px) {
    .app-main {
        margin-left: 0;
    }

    .main-content {
        padding: 1rem;
    }
}

@media (max-width: 480px) {
    .main-content {
        padding: 0.75rem;
    }
}
