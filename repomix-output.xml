                            <div className={styles.subLinks}>
                                {CORNERS.map(c => (
                                    <NavLink
                                        key={c.path}
                                        to={c.path}
                                        end
                                        className={({ isActive }) =>
                                            `${styles.link} ${styles.subLink}${isActive ? ` ${styles.active}` : ""}`
                                        }
                                        onClick={onClose}
                                    >
                                        {c.label}
                                        <span className={styles.cornerCount}>{cornerCounts[c.key] ?? 0}</span>
                                    </NavLink>
                                ))}
                            </div>
